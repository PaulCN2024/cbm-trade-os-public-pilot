{
  "outputDirectory": ".",
  "routes": [
    {
      "src": "^/trade-os-prototype(?:/index(?:\\.html)?)?/?$",
      "dest": "/api/trade-os-prototype"
    },
    {
      "src": "^/trade-website(?:/index(?:\\.html)?)?/?$",
      "dest": "/api/trade-website"
    },
    {
      "src": "^/admin/login(?:/index(?:\\.html)?)?/?$",
      "dest": "/api/admin-login"
    },
    {
      "src": "^/admin/dev-test(?:/index(?:\\.html)?)?/?$",
      "dest": "/api/admin-dev-test"
    },
    {
      "src": "^/admin/system-check(?:/index(?:\\.html)?)?/?$",
      "dest": "/api/admin-system-check"
    },
    {
      "src": "^/admin/command-center(?:/index(?:\\.html)?)?/?$",
      "dest": "/api/admin-system-check?page=command-center"
    },
    {
      "src": "^/api/companies$",
      "dest": "/api/customers?crm_resource=companies"
    },
    {
      "src": "^/api/products$",
      "dest": "/api/customers?crm_resource=products"
    },
    {
      "src": "^/api/manufacturing-capabilities$",
      "dest": "/api/customers?crm_resource=manufacturing-capabilities"
    },
    {
      "src": "^/api/ai-inquiry-analyses$",
      "dest": "/api/customers?crm_resource=ai-inquiry-analyses"
    },
    {
      "src": "^/api/follow-ups$",
      "dest": "/api/customers?crm_resource=follow-ups"
    },
    {
      "src": "^/api/admin-dashboard-summary$",
      "dest": "/api/customers?crm_resource=admin-dashboard-summary"
    },
    {
      "src": "^/api/admin-read/(dashboard-summary|customers|inquiries)$",
      "dest": "/api/admin-read?resource=$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
